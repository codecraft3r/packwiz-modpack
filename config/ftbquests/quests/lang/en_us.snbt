{
	file.0000000000000001.title: "Poiesis: The Living Atlas"
	chapter.1A0B1A4E5A9E0000.title: "00 · A Blank Page"
	reward_table.1A0B1A4E5A9E1000.title: "Choose Tonight's Lens"

	quest.1A0B1A4E5A9E0001.quest_desc: [
		"{image:minecraft:textures/item/filled_map.png width:48 height:48 align:center}"
		"&6&lTHE INK IS READY. PROBABLY."
		""
		"&fYour field notes are complete and your witness has signed off. Click the checkmark below to stamp the first page before it develops legs."
		""
		"&eThen claim both rewards:"
		"&f- &62 Bevels &7(16 Spurs; finite, one-time spending money)"
		"&f- &d1 expedition lens &7(a silly cosmetic badge with no combat power)"
		""
		"&8If the page bites, notify management. Management is a Slowpoke."
	]
	quest.1A0B1A4E5A9E0001.quest_subtitle: "Three field notes in. One dramatic stamp out."
	quest.1A0B1A4E5A9E0001.title: "&6&lSTAMP THE FIRST PAGE"

	quest.1A0B1A4E5A9E0002.quest_desc: [
		"{image:minecraft:textures/item/writable_book.png width:48 height:48 align:center}"
		"&e&lWELCOME, TINY CARTOGRAPHER"
		""
		"&fThis is a one-session expedition. You can do the three field routes in any order after clicking the checkmark below."
		""
		"&b1. &fCatch two wild Pokemon."
		"&b2. &fStart one Cobblemon battle. The task ticks when the opening bell rings; winning is optional."
		"&b3. &fReturn near world spawn with another real player and both click your own rally checkmark."
		""
		"&aGreen/checkmarked nodes are done. &7Dark nodes are waiting on a dependency. Follow the lines toward the big map."
		""
		"&8Estimated time: 30-60 minutes. Estimated dignity retained: variable."
	]
	quest.1A0B1A4E5A9E0002.quest_subtitle: "Read this once; become 73% less lost."
	quest.1A0B1A4E5A9E0002.title: "&e&lSTART HERE: Read Me, Tiny Cartographer"

	quest.1A0B1A4E5A9E0003.quest_desc: [
		"{image:cobblemon:textures/item/poke_balls/poke_ball.png width:48 height:48 align:center}"
		"&c&lACQUIRE TWO WEIRD LITTLE GUYS"
		""
		"&fCatch &e2 wild Pokemon&f. Any species and any ordinary Poke Ball count. The task reads Cobblemon's built-in lifetime capture statistic and updates automatically."
		""
		"&7Already caught some this season? Excellent. The Atlas respects prior paperwork and may complete this immediately."
		""
		"&8Please do not lick the Poke Balls. This warning exists because of an incident."
	]
	quest.1A0B1A4E5A9E0003.quest_subtitle: "Any two catches. No rarity contest. No grind ladder."
	quest.1A0B1A4E5A9E0003.title: "&c&lCATCH 2: Pocket-Sized Research"

	quest.1A0B1A4E5A9E0004.quest_desc: [
		"{image:cobblemon:textures/gui/battle/battle_menu_fight.png width:64 height:32 align:center fit:true}"
		"&b&lENTER ONE RESPECTFUL ARGUMENT"
		""
		"&fStart &e1 Cobblemon battle&f. Wild, NPC, or player battles are all fair game. This built-in statistic ticks when the battle starts; you do &nnot&r&f need to win."
		""
		"&aWhy participation counts:&f this is an icebreaker, not an arms race. A veteran cannot farm newer players for a better reward."
		""
		"&8Shake hands afterward. Pokemon may substitute a threatening chirp."
	]
	quest.1A0B1A4E5A9E0004.quest_subtitle: "Enter a battle. Victory is emotionally optional."
	quest.1A0B1A4E5A9E0004.title: "&b&lSTART 1: A Polite Little Battle"

	quest.1A0B1A4E5A9E0005.quest_desc: [
		"{image:minecraft:textures/block/amethyst_cluster.png width:48 height:48 align:center}"
		"&d&lBRING A WITNESS"
		""
		"&fMeet another non-spectator player near &eworld spawn / the Atlas archive&f. Stand together, perform whatever solemn ceremony feels appropriate, then &aclick the checkmark below&f."
		""
		"&6Important:&f this is intentionally an honor-system checkmark. If you arrived together, the page trusts you. A bold choice for a haunted book."
		""
		"&7Each player completes this step for their own personal FTB team. Late joiners are never locked out."
		""
		"&8Approved ceremonies include jumping, crouching, spinning, and saying 'behold, paperwork.'"
	]
	quest.1A0B1A4E5A9E0005.quest_subtitle: "Meet at spawn, then click. The book trusts you. Terrifying."
	quest.1A0B1A4E5A9E0005.title: "&d&lMEET A BUDDY: Sign the Clause"

	quest.1A0B1A4E5A9E0006.quest_desc: [
		"{image:minecraft:textures/item/spyglass.png width:48 height:48 align:center}"
		"&e&lBUTTONS! TERRIFYING!"
		""
		"&f- Open FTB Quests from the &ebook icon in your inventory&f."
		"&f- Hover the &eleft edge&f to reveal chapters; pin it if it keeps fleeing."
		"&f- Drag empty space to pan. Hold &eCtrl + mouse wheel&f to zoom."
		"&f- Stat tasks complete automatically. A square tickbox means &eclick it yourself&f."
		"&f- Finished quests can have unclaimed rewards. Open them and click every reward icon."
		"&f- The lens reward asks you to choose exactly one role. They are equal-power cosmetics."
		""
		"&7This help node is optional. Click its checkmark when your fear of interfaces has subsided."
	]
	quest.1A0B1A4E5A9E0006.quest_subtitle: "A tiny manual for the violently curious."
	quest.1A0B1A4E5A9E0006.title: "&eHOW TO USE THIS SILLY BOOK"

	quest.1A0B1A4E5A9E0007.quest_desc: [
		"{image:minecraft:textures/item/firework_rocket.png width:48 height:48 align:center}"
		"&a&lNOW CAUSE PROBLEMS (COOPERATIVELY)"
		""
		"&fYou finished Session 00. Spend your Spurs on the path you actually enjoy: Pokemon, magic, machinery, building, or something deeply inadvisable."
		""
		"&bSuggested afterparty:&f show off your two catches, hold a tiny exhibition bracket, or help a late arrival finish their page. Bragging rights are permitted. Power prizes are not."
		""
		"&6Your lens is a roleplay prompt, not a class lock:&f"
		"&cTrainer &7- bring a battle idea"
		"&dArcanist &7- bring a magical complication"
		"&6Engineer &7- bring an unnecessarily elaborate machine"
		"&aScout &7- bring a place everyone should see"
		""
		"&8Click the checkmark when you have selected your preferred flavor of nonsense."
	]
	quest.1A0B1A4E5A9E0007.quest_subtitle: "The tutorial is over. The consequences begin."
	quest.1A0B1A4E5A9E0007.title: "&aSession 00 Afterparty"

	reward.1A0B1A4E5A9E0021.title: "&6Field Grant - 16 Spurs"
	reward.1A0B1A4E5A9E0022.title: "&dChoose Your Expedition Lens"
	task.1A0B1A4E5A9E0011.title: "Catch Two Wild Pokemon"
	task.1A0B1A4E5A9E0012.title: "Start One Cobblemon Battle"
	task.1A0B1A4E5A9E0013.title: "We Met at the Atlas - Sign Here"
	task.1A0B1A4E5A9E0014.title: "I Read the Tiny Briefing"
	task.1A0B1A4E5A9E0015.title: "STAMP IT"
	task.1A0B1A4E5A9E0016.title: "I Now Understand Buttons"
	task.1A0B1A4E5A9E0017.title: "I Chose My Flavor of Nonsense"

	chapter.1A0B1A4E5A9E0100.title: "01 · The First Resonance"
	reward_table.1A0B1A4E5A9E2000.title: "Choose a Practical Favor"

	quest.1A0B1A4E5A9E0101.quest_desc: [
		"{image:poiesis:textures/questpics/first_resonance_key_art.png width:176 height:220 align:center}"
		"&6&lTHE FIRST RESONANCE"
		""
		"&fThe Atlas has stopped pretending it is an ordinary book. For one week it is listening for &eany three&f kinds of fieldwork."
		""
		"&7Pick the lenses that sound fun. Catch things. Make something. Go somewhere. Do a little magic. Join a raid. There is no best route and no bonus for trying to speedrun all five before lunch."
		""
		"&dYour field marks are personal and one-time.&f The server's wider celebration happens when enough different people leave their own marks."
		""
		"&8A note in the margin reads: 'Please do not tune the book with a hammer.'"
	]
	quest.1A0B1A4E5A9E0101.quest_subtitle: "Choose any three lenses. Let someone else be good at the other things."
	quest.1A0B1A4E5A9E0101.title: "&6&lOPEN THE RESONANCE PAGE"

	quest.1A0B1A4E5A9E0102.quest_desc: [
		"{image:cobblemon:textures/item/poke_balls/poke_ball.png width:48 height:48 align:center}"
		"&b&lSTAR-LENS: LITTLE CONSTELLATIONS"
		""
		"&fCatch &e5 Pokémon&f and begin &e3 Cobblemon battles&f. The Atlas does not grade species, rarity, win rate, IVs, or the emotional intensity of your nickname choices."
		""
		"&7These are lifetime statistics, so experienced trainers may finish immediately. That is intentional: the reward is a capped field mark, not a lead over anyone else."
		""
		"&8The illustrated star chart has one suspiciously round constellation labelled only 'friend-shaped.'"
	]
	quest.1A0B1A4E5A9E0102.quest_subtitle: "Capture five. Start three arguments. Keep the notes friendly."
	quest.1A0B1A4E5A9E0102.title: "&b&lSTAR-LENS: CATCH & BATTLE"

	quest.1A0B1A4E5A9E0103.quest_desc: [
		"{image:irons_spellbooks:textures/item/arcane_essence.png width:48 height:48 align:center}"
		"&d&lCINDER-LENS: A QUIET SPARK"
		""
		"&fCarry &e8 Arcane Essence&f and &e8 Amethyst Shards&f. The book is checking your inventory only; it will not eat your reagents."
		""
		"&7This is a modest signal that you have touched the magic side of the pack. Find, craft, trade, or receive help with it—there is no purity test and no demand for a particular spell build."
		""
		"&8Do not store the smoke in a jar. The last scholar who did this is technically still arguing with it."
	]
	quest.1A0B1A4E5A9E0103.quest_subtitle: "Bring a small reagent bundle. Keep every finger you arrived with."
	quest.1A0B1A4E5A9E0103.title: "&d&lCINDER-LENS: ARCANE REAGENTS"

	quest.1A0B1A4E5A9E0104.quest_desc: [
		"{image:create:textures/item/andesite_alloy.png width:48 height:48 align:center}"
		"&6&lBRASS-LENS: REMEMBERED MOTION"
		""
		"&fCarry &e8 Andesite Alloy&f and &e4 Cogwheels&f. Nothing is consumed. The Atlas just wants proof that you have taught stone and metal to cooperate."
		""
		"&7A starter machine, a half-built belt line, or a gloriously unnecessary crank all count in spirit. This is an invitation into Create, not a factory inspection."
		""
		"&8The book's tiny gear drawing rotates when nobody is looking. Probably a printing defect."
	]
	quest.1A0B1A4E5A9E0104.quest_subtitle: "A little alloy. A few gears. One future maintenance problem."
	quest.1A0B1A4E5A9E0104.title: "&6&lBRASS-LENS: CALIBRATE A MACHINE"

	quest.1A0B1A4E5A9E0105.quest_desc: [
		"{image:minecraft:textures/item/filled_map.png width:48 height:48 align:center}"
		"&a&lROOT-LENS: THE ROAD REMEMBERS"
		""
		"&fBring back one &eFilled Map&f and &e12 Amethyst Shards&f. The map must have actually been used; a blank one is a promise, not a field note."
		""
		"&7Anywhere is valid. Follow a river, find a view, mark a base route, visit a biome you have never seen, or map the inconvenient hill that keeps catching people on the way home."
		""
		"&8The Atlas deeply respects a map containing only the words 'probably bees.'"
	]
	quest.1A0B1A4E5A9E0105.quest_subtitle: "Use a map. Find a place. Make the world feel larger."
	quest.1A0B1A4E5A9E0105.title: "&a&lROOT-LENS: MAKE A FIELD MAP"

	quest.1A0B1A4E5A9E0106.quest_desc: [
		"{image:minecraft:textures/block/amethyst_cluster.png width:48 height:48 align:center}"
		"&3&lCHORUS-LENS: A VICTORY WITH WITNESSES"
		""
		"&fBegin &e5 Cobblemon battles&f, then tick the second task after you have joined or hosted a Raid Den outing with at least one other person."
		""
		"&7The battles are automatic. The raid check is deliberately trust-based because the interesting part is not the server log; it is having an excuse to show up for somebody else's strange plan."
		""
		"&8If the raid goes badly, record the disaster accurately. Future scholars deserve the warning."
	]
	quest.1A0B1A4E5A9E0106.quest_subtitle: "Five battles and one shared Raid Den story."
	quest.1A0B1A4E5A9E0106.title: "&3&lCHORUS-LENS: RAID WITH COMPANY"

	quest.1A0B1A4E5A9E0107.quest_desc: [
		"{image:poiesis:textures/questpics/resonance_specimen_sheet.png width:156 height:156 align:center}"
		"&6&lRESOLVE THE FIRST RESONANCE"
		""
		"&fComplete &eany 3 of the 5 lenses&f, then stamp this page. The Atlas needs different kinds of work, not one player doing every job."
		""
		"&dYour rewards:&f"
		"&f- &62 Bevels&7, a small flexible grant"
		"&f- &eResonant Folio&7, a non-power keepsake"
		"&f- &bOne practical favor&7: Poké Balls, Arcane Essence, Andesite Alloy, or an Explorer's Compass"
		""
		"&7The host may announce the server's shared page-opening when the group reaches 12 total lens completions. This chapter intentionally keeps that moment social rather than secretly automating it."
		""
		"&8Four specimens. Three marks. One book that is trying very hard not to glow."
	]
	quest.1A0B1A4E5A9E0107.quest_subtitle: "Any three lenses. One useful favor. No single hero required."
	quest.1A0B1A4E5A9E0107.title: "&6&lTHE FIRST RESONANCE"

	quest.1A0B1A4E5A9E0108.quest_desc: [
		"{image:minecraft:textures/item/firework_star.png width:48 height:48 align:center}"
		"&e&lAFTER THE GLOW"
		""
		"&fYou have resolved your own page. If you have time this week, the nicest possible next move is helping a late player find a lens that suits them."
		""
		"&7Trainer, mage, maker, scout, and raid companion are not classes. They are invitations to make the next server story slightly more interesting."
		""
		"&8The Atlas has begun drafting a second page in suspiciously enthusiastic handwriting."
	]
	quest.1A0B1A4E5A9E0108.quest_subtitle: "Your mark is in. Make room for another."
	quest.1A0B1A4E5A9E0108.title: "&e&lLEAVE THE MARGIN WARM"

	reward.1A0B1A4E5A9E0211.title: "&bStar-Lens Field Mark"
	reward.1A0B1A4E5A9E0212.title: "&6One Bevel"
	reward.1A0B1A4E5A9E0231.title: "&dCinder-Lens Field Mark"
	reward.1A0B1A4E5A9E0232.title: "&6One Bevel"
	reward.1A0B1A4E5A9E0251.title: "&6Brass-Lens Field Mark"
	reward.1A0B1A4E5A9E0252.title: "&6One Bevel"
	reward.1A0B1A4E5A9E0271.title: "&aRoot-Lens Field Mark"
	reward.1A0B1A4E5A9E0272.title: "&6One Bevel"
	reward.1A0B1A4E5A9E0291.title: "&3Chorus-Lens Field Mark"
	reward.1A0B1A4E5A9E0292.title: "&6One Bevel"
	reward.1A0B1A4E5A9E02A1.title: "&6Atlas Grant — 2 Bevels"
	reward.1A0B1A4E5A9E02A2.title: "&eResonant Folio"
	reward.1A0B1A4E5A9E02A3.title: "&bChoose a Practical Favor"

	task.1A0B1A4E5A9E0111.title: "I Am Ready to Leave a Mark"
	task.1A0B1A4E5A9E0121.title: "Catch 5 Pokémon"
	task.1A0B1A4E5A9E0122.title: "Start 3 Cobblemon Battles"
	task.1A0B1A4E5A9E0131.title: "Carry 8 Arcane Essence"
	task.1A0B1A4E5A9E0132.title: "Carry 8 Amethyst Shards"
	task.1A0B1A4E5A9E0141.title: "Carry 8 Andesite Alloy"
	task.1A0B1A4E5A9E0142.title: "Carry 4 Cogwheels"
	task.1A0B1A4E5A9E0151.title: "Carry One Used Map"
	task.1A0B1A4E5A9E0152.title: "Carry 12 Amethyst Shards"
	task.1A0B1A4E5A9E0161.title: "Start 5 Cobblemon Battles"
	task.1A0B1A4E5A9E0162.title: "I Joined or Hosted a Raid Den Outing"
	task.1A0B1A4E5A9E0171.title: "I Am Ready to Resolve My Page"
	task.1A0B1A4E5A9E0181.title: "I Will Help Keep the Page Warm"

	chapter.1A0B1A4E5A9E0300.title: "02 · The Weathered Ledger"
	reward_table.1A0B1A4E5A9E3000.title: "Choose a Small, Useful Favor"

	quest.1A0B1A4E5A9E0301.quest_desc: [
		"{image:poiesis:textures/questpics/weathered_ledger_key_art.png width:176 height:220 align:center}"
		"&6&lTHE WEATHERED LEDGER"
		""
		"&fThis page was once kept by someone who understood that a settlement begins long before it has walls. A turning sail. A borrowed tool. A lamp left on for the person who is late."
		""
		"&7You have diamond tools, but no diamond-armor arms race. You have a first windmill, not an empire. That is exactly where this page belongs."
		""
		"&eFor this week, complete any 3 of 5 field routes.&f Each is a small proof that the server is becoming easier to live in together, not a demand that anyone grind ahead."
		""
		"&8Someone has written in the margin: 'A workshop is only impressive when a tired friend can use it.'"
	]
	quest.1A0B1A4E5A9E0301.quest_subtitle: "Five small routes. Pick three. Leave the heavy lifting for the machines."
	quest.1A0B1A4E5A9E0301.title: "&6&lOPEN THE WEATHERED LEDGER"

	quest.1A0B1A4E5A9E0302.quest_desc: [
		"{image:create:textures/block/windmill_bearing_side.png width:48 height:48 align:center}"
		"&b&lWIND-LENS: THE CURRENT IS SHARED"
		""
		"&fVisit, help improve, or simply learn from the server's working windmill with another player. Then tick the honest checkmark."
		""
		"&7This is deliberately not a build-detection task. The first person to finish a windmill does not get to own the entire chapter. The point is that somebody opened the door, and somebody else walked through it."
		""
		"&8If the sails are crooked, they are merely expressing local weather conditions."
	]
	quest.1A0B1A4E5A9E0302.quest_subtitle: "See the first current together. Helping counts; being first does not."
	quest.1A0B1A4E5A9E0302.title: "&b&lWIND-LENS: VISIT THE CURRENT"

	quest.1A0B1A4E5A9E0303.quest_desc: [
		"{image:create:textures/item/andesite_alloy.png width:48 height:48 align:center}"
		"&6&lPRESS-LENS: ONE GOOD CLUNK"
		""
		"&fCraft a &eMechanical Press&f. The Ledger watches Create's own advancement, so it completes automatically after the little machine exists."
		""
		"&7A press is intentionally the target: it is an early shared convenience, not a brass gate or a factory race. Make one for your own bench, or make one the next player can borrow."
		""
		"&8The ledger does not care what you press first. It is trying very hard not to suggest a commemorative spoon."
	]
	quest.1A0B1A4E5A9E0303.quest_subtitle: "A first machine that makes the next little job less annoying."
	quest.1A0B1A4E5A9E0303.title: "&6&lPRESS-LENS: A USEFUL CLUNK"

	quest.1A0B1A4E5A9E0304.quest_desc: [
		"{image:minecraft:textures/item/diamond_pickaxe.png width:48 height:48 align:center}"
		"&9&lBLUE-LENS: A TOOL, NOT A CROWN"
		""
		"&fMine your first Diamond. This is Minecraft's normal diamond advancement, so players already carrying diamond tools may see it complete immediately."
		""
		"&7That is intentional. Diamond tools are the current horizon; diamond armor is not a requirement, a prize, or a reason to leave someone behind. This route records a threshold without turning it into a podium."
		""
		"&8The blue ink has been smudged by a thumbprint and what may be pickaxe dust."
	]
	quest.1A0B1A4E5A9E0304.quest_subtitle: "Reach the tool threshold. Do not make it a throne."
	quest.1A0B1A4E5A9E0304.title: "&9&lBLUE-LENS: FIRST DIAMOND"

	quest.1A0B1A4E5A9E0305.quest_desc: [
		"{image:irons_spellbooks:textures/item/arcane_essence.png width:48 height:48 align:center}"
		"&d&lCINDER-LENS: A PLACE TO BEGIN"
		""
		"&fCraft an &eInscription Table&f. The check completes from Iron's Spellbooks' own advancement."
		""
		"&7This is a gentle doorway, not a spell build. The table is where a curious player can start asking questions, where an experienced mage can leave a note, and where nobody is expected to already know the answers."
		""
		"&8The page has a coffee ring around the word 'carefully.' It feels earned."
	]
	quest.1A0B1A4E5A9E0305.quest_subtitle: "Put down a first table. Let the complicated part wait."
	quest.1A0B1A4E5A9E0305.title: "&d&lCINDER-LENS: INSCRIBE A BEGINNING"

	quest.1A0B1A4E5A9E0306.quest_desc: [
		"{image:cobblemon:textures/gui/battle/battle_menu_fight.png width:64 height:32 align:center fit:true}"
		"&3&lCHORUS-LENS: ANOTHER CHAIR AT THE TABLE"
		""
		"&fReach &e8 Pokemon caught&f and &e8 Cobblemon battles started&f, then tick the final box after joining or hosting a Raid Den outing with another person."
		""
		"&7The two numbers are lifetime statistics: if you were already active, they may be partly done. The fresh part is the shared outing. A raid win is lovely; a story about a spectacular loss is equally valid."
		""
		"&8Please allow the smallest Pokemon to make at least one tactical recommendation."
	]
	quest.1A0B1A4E5A9E0306.quest_subtitle: "A few more field notes, one Raid Den story, at least two witnesses."
	quest.1A0B1A4E5A9E0306.title: "&3&lCHORUS-LENS: MAKE ROOM"

	quest.1A0B1A4E5A9E0307.quest_desc: [
		"{image:poiesis:textures/questpics/weathered_ledger_key_art.png width:132 height:165 align:center}"
		"&6&lCLOSE THE WEATHERED LEDGER"
		""
		"&fComplete &eany 3 of the 5 lenses&f, then stamp the page. Three different kinds of ordinary work are enough to make a place feel inhabited."
		""
		"&dYour capped rewards:&f"
		"&f- &62 Bevels&7, bringing an any-three completion to 5 Bevels total"
		"&f- &eWeathered Folio&7, a keepsake with no combat power"
		"&f- &bOne useful favor&7: goggles, a Nature's Compass, Poke Balls, or Arcane Essence"
		""
		"&7No armor, diamonds, XP, enchantments, rare Pokemon, brass, or factory skip hides behind this page. It should shorten a small annoyance, not manufacture a winner."
	]
	quest.1A0B1A4E5A9E0307.quest_subtitle: "Any three routes. One modest favor. A little more room for everyone."
	quest.1A0B1A4E5A9E0307.title: "&6&lSEAL THE LEDGER"

	quest.1A0B1A4E5A9E0308.quest_desc: [
		"{image:minecraft:textures/item/lantern.png width:48 height:48 align:center}"
		"&e&lLEAVE A LANTERN ON"
		""
		"&fIf you have fifteen minutes left this week, help somebody begin one very small job: point out the windmill, lend a press, walk them to diamonds, host a Raid Den, or stand nearby while their first spell goes wrong."
		""
		"&7There is no reward because the entire point is that the server still feels worth returning to after one person gets busy."
		""
		"&8The lantern in the illustration is not magical. It is just on. That matters."
	]
	quest.1A0B1A4E5A9E0308.quest_subtitle: "A small invitation is better than a grand announcement."
	quest.1A0B1A4E5A9E0308.title: "&e&lAFTER THE ENTRY"

