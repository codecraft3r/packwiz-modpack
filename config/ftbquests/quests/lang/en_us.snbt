	chapter.1A0B1A4E5A9E0400.title: "The Atlas Exchange"

	quest.1A0B1A4E5A9E0401.quest_desc: [
		"{image:numismatics:textures/item/coin/bevel.png width:48 height:48 align:center}"
		"&6&lTHE EXCHANGE WINDOW IS OPEN"
		""
		"&fBevels are no longer decorative. &e1 Bevel is 8 Spurs&f, and this page turns physical Bevels into deliberate early-game help."
		""
		"&eHow it works:&f keep the Bevels in your inventory, open an offer, and click its gold Bevel task to submit the exact payment. Carrying coins alone does not complete the purchase."
		""
		"&cSmall-team rule:&f FTB Quest progress is shared by FTB team. Each offer issues exactly &eone team cache&f to the player who claims it, then renews &e7 days after claim&f. Agree on the buyer and handoff first."
		""
		"&7No offer pays currency back, sells diamond gear, skips brass, or generates a loop. Spend for a useful nudge, not an advantage that makes other people stop playing."
	]
	quest.1A0B1A4E5A9E0401.quest_subtitle: "A real sink for Bevels: modest, team-safe, and intentionally finite."
	quest.1A0B1A4E5A9E0401.title: "&6&lREAD THE EXCHANGE TERMS"

	quest.1A0B1A4E5A9E0402.quest_desc: [
		"{image:create:textures/item/andesite_alloy.png width:48 height:48 align:center}"
		"&6&lKINETIC CACHE - 2 BEVELS"
		""
		"&fSubmit &e2 Bevels&f for one shared cache: &e4 Andesite Alloy, 8 Shafts, and 4 Cogwheels.&f"
		""
		"&7This starts a small machine job without handing out a power source, brass, or a factory. Put it where the next person can use it."
		""
		"&8Renews seven days after the cache is claimed."
	]
	quest.1A0B1A4E5A9E0402.quest_subtitle: "Two coins for the boring parts that make a first machine possible."
	quest.1A0B1A4E5A9E0402.title: "&6&lEXCHANGE: KINETIC CACHE"

	quest.1A0B1A4E5A9E0403.quest_desc: [
		"{image:create:textures/block/axis.png width:48 height:48 align:center}"
		"&e&lPUBLIC-WORKS PRESS - 3 BEVELS"
		""
		"&fSubmit &e3 Bevels&f for one &eMechanical Press and Basin.&f"
		""
		"&7This is the deliberately big early offer. It is a shared-workshop purchase, not private armor or a tech-tier skip: somebody still needs to power it, learn it, and leave room around it."
		""
		"&8Claim beside a shared chest or the intended builder. Only one team cache exists."
	]
	quest.1A0B1A4E5A9E0403.quest_subtitle: "Three coins for a public tool, not a personal lead."
	quest.1A0B1A4E5A9E0403.title: "&e&lEXCHANGE: PUBLIC-WORKS PRESS"

	quest.1A0B1A4E5A9E0404.quest_desc: [
		"{image:create:textures/item/super_glue.png width:48 height:48 align:center}"
		"&a&lBUILDER'S GLUE - 1 BEVEL"
		""
		"&fSubmit &e1 Bevel&f for &e8 Super Glue.&f"
		""
		"&7This is pure utility: a modest construction helper for the windmill, a bridge, a silly moving sign, or the kind of compact build that only makes sense once you are halfway through it."
		""
		"&8No combustion-based adhesive incidents are covered by the Ledger."
	]
	quest.1A0B1A4E5A9E0404.quest_subtitle: "One coin for better connections, mechanical and otherwise."
	quest.1A0B1A4E5A9E0404.title: "&a&lEXCHANGE: BUILDER'S GLUE"

	quest.1A0B1A4E5A9E0405.quest_desc: [
		"{image:minecraft:textures/item/compass_16.png width:48 height:48 align:center}"
		"&b&lSURVEY WARRANT - 3 BEVELS"
		""
		"&fSubmit &e3 Bevels&f for an &eExplorer's Compass.&f"
		""
		"&7It finds structures; it does not find courage, food, safe routes home, or friends willing to retrieve your backpack. That makes it valuable without being a power leap."
		""
		"&8The paperwork says 'Expedition approved.' The margin says 'probably bees.'"
	]
	quest.1A0B1A4E5A9E0405.quest_subtitle: "Spend three coins to make exploration more intentional."
	quest.1A0B1A4E5A9E0405.title: "&b&lEXCHANGE: SURVEY WARRANT"

	quest.1A0B1A4E5A9E0406.quest_desc: [
		"{image:irons_spellbooks:textures/item/arcane_essence.png width:48 height:48 align:center}"
		"&d&lCINDER REAGENT KIT - 2 BEVELS"
		""
		"&fSubmit &e2 Bevels&f for &e8 Arcane Essence and 8 Amethyst Shards.&f"
		""
		"&7A starting nudge for the person who wants to try magic without being told that they must commit their whole week to it. It does not contain a spellbook, a build, or a superiority complex."
		""
		"&8Please label the jar before it begins to hum."
	]
	quest.1A0B1A4E5A9E0406.quest_subtitle: "Two coins for a curiosity, not a class choice."
	quest.1A0B1A4E5A9E0406.title: "&d&lEXCHANGE: CINDER REAGENT KIT"

	quest.1A0B1A4E5A9E0407.quest_desc: [
		"{image:cobblemon:textures/item/poke_balls/great_ball.png width:48 height:48 align:center}"
		"&9&lTRAINER'S SATCHEL - 2 BEVELS"
		""
		"&fSubmit &e2 Bevels&f for &e4 Great Balls.&f"
		""
		"&7This is a little more interesting than another stack of ordinary Poke Balls, but it is not a rare-Pokemon shortcut. Take the friend who is behind on catches with you."
		""
		"&8The satchel smells faintly of apricorns and impossible confidence."
	]
	quest.1A0B1A4E5A9E0407.quest_subtitle: "Two coins for a better chance, never a guaranteed story."
	quest.1A0B1A4E5A9E0407.title: "&9&lEXCHANGE: TRAINER'S SATCHEL"

	quest.1A0B1A4E5A9E0408.quest_desc: [
		"{image:minecraft:textures/item/book.png width:48 height:48 align:center}"
		"&e&lTHE LEDGER'S SHORT VERSION"
		""
		"&fSpend Bevels on horizontal utility. Choose a tool that makes the next shared evening smoother. Let the offer renew next week instead of trying to spend your whole balance tonight."
		""
		"&7If the group later wants a physical spawn market, a host can build Numismatics vendors. This page exists now so the coins already in circulation are useful before that project happens."
		""
		"&8A currency without a choice is just a very shiny reminder."
	]
	quest.1A0B1A4E5A9E0408.quest_subtitle: "Spend with intent. Make the next session easier to join."
	quest.1A0B1A4E5A9E0408.title: "&e&lMARK THE TERMS UNDERSTOOD"

